    family-names: Lai
    alias: devin-lai
repository-code: "https://github.com/devin-lai/onnx2coreml"
url: "https://github.com/devin-lai/onnx2coreml"
license: BSD-3-Clause
keywords:
  - onnx
  - core-ml
  - coreml
  - mlpackage
  - mlmodel
  - model-conversion
  - apple-silicon
  - on-device-inference
  - coremltools
